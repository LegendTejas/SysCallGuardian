# SysCallGuardian — Environment Configuration
# Copy this file to .env and edit values for your environment
# Never commit .env to version control

# Flask
SECRET_KEY=change_this_to_a_random_secret_in_production
DEBUG=true
PORT=5000

# JWT
JWT_SECRET=change_this_jwt_secret_in_production
TOKEN_EXPIRY_H=8

# Database
# Leave as default for SQLite (recommended for development)
# Set to an absolute path to store DB elsewhere
DB_PATH=syscall_gateway.db

# Testing
# Set to true only when running pytest — switches DB to :memory:
TESTING=false

# Sandbox
# Root directory for file operations — all relative paths resolve here
SANDBOX_ROOT=./sandbox
